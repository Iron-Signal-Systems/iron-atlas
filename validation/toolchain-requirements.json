{
  "schema_version": 1,
  "project": "Iron Atlas",
  "canonical_repository": "https://github.com/Iron-Signal-Systems/atlas.git",
  "canonical_branch": "dev",
  "requirements": {
    "bash": {
      "minimum": "5.0"
    },
    "git": {
      "minimum": "2.39"
    },
    "go": {
      "minimum": "1.26.5",
      "maximum_exclusive": "1.27",
      "language_version": "1.25.0",
      "preferred_toolchain": "go1.26.5"
    },
    "python": {
      "minimum": "3.11"
    },
    "postgresql": {
      "minimum": "14",
      "commands": [
        "postgres",
        "initdb",
        "pg_ctl",
        "pg_isready",
        "createdb",
        "psql"
      ]
    },
    "utilities": [
      "awk",
      "find",
      "grep",
      "mktemp",
      "sed",
      "sha256sum",
      "tee",
      "timeout"
    ]
  },
  "dependency_verification": [
    "go mod download",
    "go mod verify"
  ],
  "disposable_test_environment": "test-framework/database/run_disposable_postgres.sh",
  "repository_secrets": "prohibited",
  "non_repository_secrets": [],
  "go_tools": [
    {
      "command": "govulncheck",
      "package": "golang.org/x/vuln/cmd/govulncheck",
      "module": "golang.org/x/vuln",
      "version": "v1.6.0",
      "invocation": "go tool govulncheck"
    }
  ],
