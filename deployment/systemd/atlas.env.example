# Install as /etc/iron-atlas/iron-atlas.env with root ownership and mode 0600.
IRON_ATLAS_CHANGE_STORE=postgresql
IRON_ATLAS_DEV_IDENTITY=false
IRON_ATLAS_DATABASE_MAX_CONNECTIONS=8
IRON_ATLAS_DATABASE_MIN_CONNECTIONS=0

# Supply a real URL only through protected deployment secret handling.
# IRON_ATLAS_DATABASE_URL=postgres://atlas_application:REDACTED@db.example/iron_atlas?sslmode=verify-full
