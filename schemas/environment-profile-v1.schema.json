{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ironsignalsystems.com/schemas/isras/environment-profile-v1.schema.json",
  "title": "ISRAS Environment Profile v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile",
    "classification",
    "required_commands",
    "capabilities"
  ],
  "properties": {
    "schema_version": {
      "const": "ISRAS-ENVIRONMENT-V1"
    },
    "profile": {
      "type": "string",
      "minLength": 1
    },
    "classification": {
      "enum": [
        "portable",
        "canonical",
        "specialized",
        "release",
        "recovery"
      ]
    },
    "operating_systems": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "architectures": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "required_commands": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/commandRequirement"
      },
      "uniqueItems": true
    },
    "optional_commands": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/commandRequirement"
      },
      "uniqueItems": true
    },
    "required_python_modules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "module",
          "distribution",
          "version"
        ],
        "properties": {
          "module": {
            "type": "string",
            "minLength": 1
          },
          "distribution": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "uniqueItems": true
    },
    "required_environment_variables": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z_][A-Z0-9_]*$"
      },
      "uniqueItems": true
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "containers_required": {
      "type": "boolean"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "commandRequirement": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "command"
          ],
          "properties": {
            "command": {
              "type": "string",
              "minLength": 1
            },
            "version_args": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "version_pattern": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "operating_systems": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": true
            }
          }
        }
      ]
    }
  }
}
