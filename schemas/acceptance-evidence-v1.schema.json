{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ironsignalsystems.com/schemas/isras/acceptance-evidence-v1.schema.json",
  "title": "ISRAS Acceptance Evidence v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "repository",
    "source_commit",
    "source_branch",
    "standard_commit",
    "validator",
    "runner_identity",
    "environment_profile",
    "environment_fingerprint",
    "correctness_result",
    "resource_observation",
    "performance_budget",
    "security_findings",
    "operational_readiness",
    "started_at",
    "finished_at",
    "warnings",
    "non_claims",
    "artifacts"
  ],
  "properties": {
    "schema_version": { "const": "ISRAS-ACCEPTANCE-EVIDENCE-V1" },
    "repository": { "type": "string", "pattern": "^[^/]+/[^/]+$" },
    "source_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "source_branch": { "type": "string", "minLength": 1 },
    "accepted_predecessor": {
      "type": ["string", "null"],
      "pattern": "^[0-9a-f]{40}$"
    },
    "acceptance_tag": { "type": ["string", "null"] },
    "standard_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "validator": { "type": "string", "minLength": 1 },
    "runner_identity": { "type": "string", "minLength": 3 },
    "environment_profile": { "type": "string", "minLength": 1 },
    "environment_fingerprint": {
      "type": "object",
      "required": [
        "profile",
        "classification",
        "host",
        "operating_system",
        "operating_system_release",
        "architecture",
        "python_version",
        "commands",
        "python_modules",
        "repository_commit"
      ]
    },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "correctness_result": { "enum": ["PASS", "FAIL"] },
    "resource_observation": { "enum": ["RECORDED", "NOT_RECORDED", "NOT_APPLICABLE"] },
    "performance_budget": { "enum": ["PASS", "FAIL", "NOT_EVALUATED", "NOT_APPLICABLE"] },
    "security_findings": { "enum": ["NONE", "RECORDED", "NOT_EVALUATED"] },
    "operational_readiness": { "enum": ["ACCEPTED", "NOT_ACCEPTED", "NOT_EVALUATED"] },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "non_claims": {
      "type": "array",
      "items": { "type": "string" }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    }
  }
}
