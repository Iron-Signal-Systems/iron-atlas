# Non-secret runtime mode selection.
IRON_ATLAS_CHANGE_STORE=postgresql
IRON_ATLAS_DEV_IDENTITY=false
IRON_ATLAS_DATABASE_MAX_CONNECTIONS=8
IRON_ATLAS_DATABASE_MIN_CONNECTIONS=0

# Supply IRON_ATLAS_DATABASE_URL through protected runtime secret delivery.
# Do not commit a real URL, username, password, certificate, or token.
# Example shape only:
# IRON_ATLAS_DATABASE_URL=postgres://atlas_application:REDACTED@localhost/iron_atlas?sslmode=verify-full
